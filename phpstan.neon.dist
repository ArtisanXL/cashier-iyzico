includes:
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    configDirectories:
        - config
    ignoreErrors:
        # Billable and its Concerns are public traits applied to the host app's
        # models, so no class in src/ uses them and PHPStan skips them as unused.
        - identifier: trait.unused
