{
    "name": "artisanxl/cashier-iyzico",
    "description": "Laravel Cashier driver for Iyzico payments",
    "keywords": [
        "ArtisanXL",
        "laravel",
        "cashier-iyzico"
    ],
    "homepage": "https://github.com/artisanxl/cashier-iyzico",
    "license": "MIT",
    "authors": [
        {
            "name": "Mertcan Dinler",
            "email": "mertdinlerin@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "iyzico/iyzipay-php": "^2.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "captainhook/captainhook": "^5.29",
        "captainhook/hook-installer": "^1.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.0.0||^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "ArtisanXL\\CashierIyzico\\": "src/",
            "ArtisanXL\\CashierIyzico\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ArtisanXL\\CashierIyzico\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true,
            "captainhook/hook-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ArtisanXL\\CashierIyzico\\CashierIyzicoServiceProvider"
            ],
            "aliases": {
                "CashierIyzico": "ArtisanXL\\CashierIyzico\\Facades\\CashierIyzico"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
